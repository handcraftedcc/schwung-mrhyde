{
  "title": "Freak",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "MicroFreak-inspired",
        "Plaits-based synth",
        "for Move Anything.",
        "",
        "Core controls are",
        "top-level params",
        "with a single Mod",
        "submenu."
      ]
    },
    {
      "title": "Engine",
      "lines": [
        "Model: Plaits",
        "engine name",
        "Harmonics: macro",
        "Timbre: macro",
        "Morph: macro",
        "FM Amount: depth",
        "Pitch: semitone",
        "offset"
      ]
    },
    {
      "title": "LPG",
      "lines": [
        "Decay: vactrol",
        "response time",
        "Color: amp/filter",
        "balance",
        "long decay keeps",
        "release tails",
        "alive until fully",
        "finished"
      ]
    },
    {
      "title": "Filter",
      "lines": [
        "Global multimode",
        "post filter",
        "Mode: LP/BP/HP",
        "Cutoff: 0..1",
        "Resonance: amt",
        "sits above Mod",
        "Sources in root",
        "layout"
      ]
    },
    {
      "title": "Mod",
      "lines": [
        "Pages:",
        " Pitch, Harmonics,",
        " Timbre, Cutoff,",
        " Assign 1/2",
        "",
        "Assign 1/2 include",
        "target + source",
        "amounts",
        "",
        "Active pages show",
        "a '*' marker."
      ]
    },
    {
      "title": "Mod Sources",
      "lines": [
        "LFO: shape/rate/",
        " sync/retrig/phase",
        " sync rate: 16 bars",
        " .. 1/64",
        "Envelope: ADSR",
        "Cycling Env:",
        " attack/decay/",
        " shape/bipolar",
        "Random: mode/rate/",
        " sync/slew/retrig",
        "Velocity curve",
        "Poly AT curve",
        "-1..+1 bipolar"
      ]
    },
    {
      "title": "Voice",
      "lines": [
        "Voice Mode:",
        " mono/poly/legato",
        "Polyphony + Unison",
        "budgeted to max",
        "8 render voices",
        "Detune + Spread",
        "Glide in 5ms",
        "steps"
      ]
    },
    {
      "title": "Disclaimer",
      "lines": [
        "Uses Mutable",
        "Instruments Plaits",
        "source under MIT",
        "license.",
        "",
        "Developed with",
        "AI assistance and",
        "human review."
      ]
    }
  ]
}
